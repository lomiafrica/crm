# Production environment for crm.lomi.africa (Railway server + worker)
# Copy values into Railway service variables. Generate secrets with: openssl rand -base64 32

SERVER_URL=https://api.crm.lomi.africa
FRONTEND_URL=https://crm.lomi.africa

# Railway references (set in dashboard after adding Postgres + Redis)
# PG_DATABASE_URL=${{Postgres.DATABASE_URL}}
# REDIS_URL=${{Redis.REDIS_URL}}

APP_SECRET=
ENCRYPTION_KEY=
FALLBACK_ENCRYPTION_KEY=

AUTH_PASSWORD_ENABLED=false
AUTH_GOOGLE_ENABLED=true
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
AUTH_GOOGLE_CALLBACK_URL=https://api.crm.lomi.africa/auth/google/callback

STORAGE_TYPE=local
IS_MULTIWORKSPACE_ENABLED=false
SIGN_IN_PREFILLED=false

# Worker service only
# DISABLE_DB_MIGRATIONS=true
# DISABLE_CRON_JOBS_REGISTRATION=true
